[user]
	name = 
	email = 

[color]
	ui = auto

[color "diff"]
	whitespace = red reverse

[rerere]
	autoupdate = false
	enabled = false

[receive]
	denyNonFastForwards = true
	updateServerInfo = true

[diff]
	wsErrorHighlight = all
	indentHeuristic = true

[push]
	default = matching
	gpgsign = false

[pull]
	ff = only

[commit]
	gpgsign = false

[init]
	defaultBranch = main

[core]
	editor = vim

[remote "upstream"]
	fetch = +refs/pull/*/head:refs/remotes/up-pr/*

[tig]
	vertical-split = false
	main-view-date = custom
	main-view-date-format = %Y-%m-%d
	main-view-author-display = abbreviated
	main-view-author-width = 10
	main-view-id = yes

[alias]
	amend = commit --amend
	co = checkout
	bd = branch -D
	st = status
	ci = commit
	cm = commit -S
	cmm = commit -S -m
	cp = cherry-pick
	br = branch --sort=committerdate
	pl = pull
	ps = push
	fix = commit -a -v -S -m 'fix'
	wip = commit -a -v -S -m 'wip'
	hist = log --pretty=format:"%h %ad | %s%d [%an]" --graph --date=short
	type = cat-file -t
	dump = cat-file -p
	mergeup = !gh pr checkout $1 && git co main && git merge --ff-only -
	nuke = !sh -c 'git branch -D $1 && git push origin :$1' -
	files = diff --name-only
	pom = push origin main
	lg = log --color --graph --pretty=format:'%Cred%h%Creset%C(yellow)%d%Creset %s %Cgreen(%an, %cn %cr) %C(bold blue)%Creset' --abbrev-commit -n 35
	lga = log --color --graph --pretty=format:'%Cred%h%Creset%C(yellow)%d%Creset %s %Cgreen(%an, %cn, %cr) %C(bold blue)%Creset' --abbrev-commit
	lgm = lg main
	fa = fetch --all
	bruteclean = !git clean -dxf && git reset --hard
	unstash = stash pop
	diff = diff --ws-error-highlight=all --indent-heuristic
	rone = reset HEAD^
	rhh = reset --hard HEAD
	gcm = checkout main
	latest = branch --sort=-committerdate
	recent-branches = for-each-ref --sort=-committerdate --count=10 --format='%(refname:short)' refs/heads/
	rib20 = rebase -i HEAD~20
	rib40 = rebase -i HEAD~40
	rib = rebase -i
	ds = diff --staged
	last = log -1 HEAD --stat
	unstage = restore --staged
	undo = reset HEAD~1 --mixed
	aliases = config --get-regexp alias
